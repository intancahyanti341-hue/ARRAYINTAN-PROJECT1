        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "nilai_mahasiswa = []\n",
        "\n",
        "\n",
        "for i in range(10):\n",
        "    while True:\n",
        "        try:\n",
        "            nilai = float(input(f\"Masukkan nilai mahasiswa ke-{i+1} (0-100): \"))\n",
        "            if 0 <= nilai <= 100:\n",
        "                nilai_mahasiswa.append(nilai)\n",
        "                break\n",
        "            else:\n",
        "                print(\"Nilai harus antara 0-100\")\n",
        "        except ValueError:\n",
        "            print(\"Masukkan angka yang valid!\")\n",
        "\n",
        "\n",
        "# Konversi ke array NumPy\n",
        "nilai_mahasiswa = np.array(nilai_mahasiswa)\n",
        "print(\"\\nNilai mahasiswa:\", nilai_mahasiswa)\n",
        "\n",
        "\n",
        "nilai_tertinggi = np.max(nilai_mahasiswa)\n",
        "nilai_terendah = np.min(nilai_mahasiswa)\n",
        "\n",
        "\n",
        "print(\"Nilai tertinggi:\", nilai_tertinggi)\n",
        "print(\"Nilai terendah:\", nilai_terendah)\n",
        "\n",
        "\n",
        "rata_rata = np.mean(nilai_mahasiswa)\n",
        "print(\"Rata-rata nilai:\", rata_rata)\n",
        "\n",
        "\n",
        "jumlah_lulus = np.sum(nilai_mahasiswa >= 10)\n",
        "jumlah_tidak_lulus = len(nilai_mahasiswa) - jumlah_lulus\n",
        "\n",
        "\n",
        "print(\"Jumlah mahasiswa lulus:\", jumlah_lulus)\n",
        "print(\"Jumlah mahasiswa tidak lulus:\", jumlah_tidak_lulus)\n",
        "\n",
        "\n",
        "plt.figure(figsize=(6,4))\n",
        "plt.bar(['Tertinggi','Terendah'], [nilai_tertinggi, nilai_terendah], color=['green','red'])\n",
        "plt.title(\"Nilai Tertinggi & Terendah Mahasiswa\")\n",
        "plt.ylabel(\"Nilai\")\n",
        "plt.show()\n",
        "\n",
        "\n",
        "plt.figure(figsize=(6,4))\n",
        "plt.bar(['Lulus','Tidak Lulus'], [jumlah_lulus, jumlah_tidak_lulus], color=['blue','orange'])\n",
        "plt.title(\"Data Kelulusan Mahasiswa\")\n",
        "plt.ylabel(\"Jumlah Mahasiswa\")\n",
        "plt.show()\n"
      ]
